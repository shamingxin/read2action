# Read2Action — 本地环境变量示例（勿提交真实密钥）
#
# 复制为 .env.local 后填写真实值。Vercel 请在 Project Settings → Environment Variables 配置。

# OpenAI-compatible API Key（仅服务端 Route Handler 读取，勿暴露到客户端）
AI_API_KEY=

# 可选。留空则使用 OpenAI 官方默认：https://api.openai.com/v1
# 其他兼容网关请填完整基址（勿带末尾路径，如 /v1 结尾不要重复 /chat/completions）
AI_BASE_URL=

# 模型名，如 gpt-4o-mini（以你的供应商为准）
AI_MODEL=

# Supabase（从 Project Settings → API 获取）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
